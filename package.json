{
  "name": "@deyta-ai/sdk",
  "version": "0.2.0",
  "description": "TypeScript SDK for the Deyta platform — memory, namespaces, and integrations.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run type-check && bun test && bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "latest"
  },
  "license": "MIT",
  "author": "Deyta <support@deyta.ai>",
  "homepage": "https://docs.deyta.ai/sdk/typescript",
  "bugs": {
    "email": "support@deyta.ai"
  },
  "keywords": [
    "deyta",
    "deyta-platform",
    "memory",
    "ai",
    "llm",
    "rag",
    "agent-memory",
    "sdk"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
