{
  "name": "@deyta-ai/sdk",
  "version": "0.5.0",
  "description": "TypeScript SDK for the Deyta platform — memory, namespaces, integrations, and personas.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "lint": "eslint src __tests__",
    "test": "bun test",
    "smoke": "bun run scripts/smoke/all.ts",
    "smoke:namespaces": "bun run scripts/smoke/namespaces.ts",
    "smoke:memory": "bun run scripts/smoke/memory.ts",
    "smoke:integrations": "bun run scripts/smoke/integrations.ts",
    "smoke:personas": "bun run scripts/smoke/personas.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run type-check && bun run lint && bun test && bun run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "latest",
    "typescript-eslint": "^8.0.0"
  },
  "license": "MIT",
  "author": "Deyta <support@deyta.ai>",
  "homepage": "https://docs.deyta.ai/sdk/typescript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeytaHQ/typescript-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/DeytaHQ/typescript-sdk/issues"
  },
  "keywords": [
    "deyta",
    "deyta-platform",
    "memory",
    "ai",
    "llm",
    "rag",
    "agent-memory",
    "sdk"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
